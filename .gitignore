# e2ee-visualizer — .gitignore (Next.js / TypeScript)

# Bağımlılıklar
/node_modules
/.pnp
.pnp.*

# Next.js / build çıktıları
/.next/
/out/
/build
/coverage

# TypeScript üretilenler
*.tsbuildinfo
next-env.d.ts

# Debug logları
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Deploy / hosting
.vercel

# Secrets — asla commit'lenmez (gizli değer gerekirse Core.SecretManager kullanılır)
.env
.env.*
*.key
*.pem
secrets/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
